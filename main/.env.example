# Guestbook (Supabase) — copy to .env and fill in from your Supabase project settings.
# Until both are set, the Guestbook app renders an "offline" state and the rest of the
# site works normally.
#
# Find these at: Supabase dashboard > Project Settings > API
#   VITE_SUPABASE_URL   = Project URL
#   VITE_SUPABASE_ANON_KEY = Project API keys > anon / public
#
# Then run the SQL in src/guestbook/schema.sql in the Supabase SQL editor once.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Web3Forms access key for the "Send Mail" contact form (client-side key).
# Get one at https://web3forms.com. Set this in your host's env vars too (e.g. Railway).
VITE_WEB3FORMS_KEY=
